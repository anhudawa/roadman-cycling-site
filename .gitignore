# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# YouTube sync state
scripts/sync-state.json

# SEO content drafts (generated, reviewed before publishing)
content/drafts/

# Admin analytics data (generated at runtime)
/data/events.json

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.superpowers/

# Repurpose pipeline state (local tracking)
scripts/repurpose-state.json
.claude/worktrees/

# Runtime agent logs and temp files
/logs/
/tmp/
