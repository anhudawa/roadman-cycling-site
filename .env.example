# Beehiiv Newsletter Integration
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Stripe (for Strength Training course purchases)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_STRENGTH_PRICE_ID=price_...

# Stripe Webhook (for S&C purchase notifications)
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (for transactional emails $�� notifications, etc.)
RESEND_API_KEY=re_...

# Site URL (set in Vercel dashboard)
NEXT_PUBLIC_SITE_URL=https://roadmancycling.com

# YouTube Sync (for scripts/sync-youtube.ts) $�� uses yt-dlp, no API key needed
YOUTUBE_CHANNEL_HANDLE=theroadmanpodcast

# Claude API (optional $�� for AI quote extraction during YouTube sync)
ANTHROPIC_API_KEY=

# Admin Dashboard
ADMIN_PASSWORD=change-me-to-something-secure

# Analytics (optional)
NEXT_PUBLIC_GA_ID=

# Sponsor reports $�� Google Analytics 4
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Ted $�� Community Agent
# Skool login (Ted's account, not Anthony's). Stored as GitHub Actions secrets in prod.
SKOOL_EMAIL=
SKOOL_PASSWORD=
SKOOL_COMMUNITY_SLUG=roadman
SKOOL_INTRO_CATEGORY=Intro Yourself
# Where Ted sends warn/error alerts (Resend-powered; optional for local dev)
TED_ADMIN_ALERT_EMAIL=
TED_ALERT_FROM=ted@roadmancycling.com
# Postgres URL $�� GitHub Actions needs this so drafting/posting/logging can write
POSTGRES_URL=

# Optional $�� enables manual workflow triggers from /admin/ted/settings.
# Token needs the `actions:write` scope on GITHUB_REPO.
GITHUB_TOKEN=
GITHUB_REPO=anhudawa/roadman-cycling-site
GITHUB_DEFAULT_BRANCH=main

# $��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��
# Ask Roadman + MCP Server
# $��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��$��

# Voyage AI $�� primary embeddings provider (1024-dim voyage-3-large).
# Also used by PR #76 MCP server for episode/methodology embeddings.
VOYAGE_API_KEY=

# Embedding provider override (voyage | openai). Defaults to voyage.
EMBEDDING_PROVIDER=voyage

# OpenAI fallback for embeddings (only required if EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=

# Upstash Redis $�� sliding-window rate limiter for /api/ask + /api/mcp.
# In dev, leave empty and the limiter auto-bypasses.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Ask Roadman rate limits
#   _RPM    = requests / 10-minute window per session or IP
#   _DAILY  = requests / 24h per session or IP (anonymous only)
#   _RPH    = requests / hour per rider profile
ASK_ROADMAN_ANON_RPM=5
ASK_ROADMAN_ANON_DAILY=10
ASK_ROADMAN_PROFILE_RPH=30

# Brand citation tests (DEV-DATA-03)
# Weekly cron tests prompts against ChatGPT, Claude, Perplexity, Gemini to
# track Roadman mentions. ANTHROPIC_API_KEY and OPENAI_API_KEY above are
# reused. PERPLEXITY_API_KEY and GOOGLE_AI_API_KEY are optional — providers
# whose key is unset are skipped silently and surfaced in the admin UI as
# "Not configured".
PERPLEXITY_API_KEY=
GOOGLE_AI_API_KEY=
